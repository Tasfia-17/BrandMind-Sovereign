# ─── REQUIRED ─────────────────────────────────────────────────────────────────
# TokenRouter — routes to deepseek/claude/gpt-4o/flux
# Get: https://bit.ly/4eG9ddG  (redeem hackathon voucher)
# Base URL: https://api.tokenrouter.com/v1
TOKENROUTER_API_KEY=tr_your_key_here

# Fish Audio — TTS synthesis
# Get: https://fish.audio/app/api-keys/
FISH_API_KEY=fish_your_key_here

# BotLearn — karma/reputation logging
# Get: https://www.botlearn.ai → Get Started → My Bots
BOTLEARN_API_KEY=botlearn_your_key_here

# fal.ai — flux-schnell image generation (~$0.003/image)
# Get: https://fal.ai/dashboard → API Keys
FAL_API_KEY=fal_your_key_here

# ─── AGENTHANSA ───────────────────────────────────────────────────────────────
# Run `python -m agenthansa.register` to get this key (starts with tabb_)
# It's only shown once — save it immediately
AGENTHANSA_KEY=tabb_your_key_here

# FluxA agent wallet ID — for receiving payments on AgentHansa
# Get: npx @fluxa-pay/fluxa-wallet@latest init --name brandmind --client python
FLUXA_AGENT_ID=

# Contact email shown on your AgentHansa expert profile
CONTACT_EMAIL=you@example.com

# ─── PAYMENTS ─────────────────────────────────────────────────────────────────
# EVM wallet address (Base mainnet) for x402 sub-agent payments
# Just your public address — no private key needed
EVM_WALLET_ADDRESS=

# ─── OPTIONAL ─────────────────────────────────────────────────────────────────
# Fish Audio reference voice ID (https://fish.audio/voices/)
FISH_VOICE_ID=

# HydraDB — ask judge Nishkarsh Srivastava at the event
HYDRADB_API_KEY=
